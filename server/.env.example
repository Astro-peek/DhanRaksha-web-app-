# Supabase Configuration
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-never-share-publicly
SUPABASE_ANON_KEY=your-supabase-anon-public-key
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# Payment Gateways (Razorpay & Cashfree)
RAZORPAY_KEY_ID=rzp_test_xxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx
CASHFREE_CLIENT_ID=cf_test_xxxxxx
CASHFREE_CLIENT_SECRET=xxxxxxxxxxxxxxxx
CASHFREE_ENV=TEST

# Blockchain / Web3 (Polygon MATIC Network)
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your-api-key
DEPLOYER_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHIT_ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
CERTIFICATE_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Redis Queue (Upstash Redis for BullMQ Queueing)
UPSTASH_REDIS_URL=rediss://default:token-password@your-upstash-instance.upstash.io:6379
UPSTASH_REDIS_TOKEN=your-upstash-redis-token-password

# AWS Storage (Certificate S3 PDF Exports)
AWS_S3_BUCKET=safekosh-certs
AWS_REGION=ap-south-1

# Google TTS (Text-to-Speech) API Key for regional calling nudges
GOOGLE_TTS_API_KEY=xxxxxxxxxxxxxxxx

# Server Setup
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173
LOG_LEVEL=info
